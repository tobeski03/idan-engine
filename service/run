#!/data/data/com.termux/files/usr/bin/sh
# runit run script for idan-engine (used by termux-services)
# This file is symlinked into ~/.termux/service/idan-engine/run by install-termux.sh
# termux-services will restart this service automatically on crash and on Termux boot.

# Resolve the engine directory from the real location of this script
SCRIPT_REAL="$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")"
ENGINE_DIR="$(dirname "$(dirname "${SCRIPT_REAL}")")"

# Load .env if it exists (runit services don't inherit the user shell env)
if [ -f "${ENGINE_DIR}/.env" ]; then
  # Export each KEY=VALUE line (skip comments and blanks)
  while IFS='=' read -r key val; do
    case "${key}" in
      ''|\#*) continue ;;
    esac
    export "${key}=${val}"
  done < "${ENGINE_DIR}/.env"
fi

# Redirect stdout+stderr to the engine log (sv log would need a log/ dir — keep it simple)
exec node "${ENGINE_DIR}/server.js" >> "${ENGINE_DIR}/engine.log" 2>&1
