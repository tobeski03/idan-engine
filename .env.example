# ── Device-level overrides (optional) ────────────────────────────────────────
# These have built-in defaults and only need to be set if you want to change them.

# Port the engine listens on (default: 3788)
# IDAN_ENGINE_PORT=3788

# Network interface to bind to (default: 0.0.0.0)
# IDAN_ENGINE_HOST=0.0.0.0
